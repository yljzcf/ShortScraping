{
  "manifest_version": 3,
  "name": "ShortScraping - 短剧监控助手",
  "version": "1.3.2",
  "description": "监控IMDB等平台的爆款短剧榜单，支持时间线展示和自动翻译",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.imdb.com/*",
    "https://api.mymemory.translated.net/*",
    "https://*/*",
    "http://*/*",
    "http://127.0.0.1:31919/*"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["src/content/content.js"],
      "css": ["src/content/content.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "options_ui": {
    "page": "src/settings/settings.html",
    "open_in_tab": true
  }
}
